// ─── STATE ──────────────────────────────────────────────────────
let selectedCategory = null;
let selectedDifficulty = 'easy';
let questions = [];
let currentQ = 0;
let score = 0;
let correct = 0;
let wrong = 0;
let answered = false;
let timerInterval = null;
let timeLeft = 30;
let totalTime = 30;
let timePerQ = [];
let userAnswers = [];
const TIMER_CIRCUMFERENCE = 2 * Math.PI * 22;

// ─── DOM ─────────────────────────────────────────────────────────
const homeScreen    = document.getElementById('homeScreen');
const quizScreen    = document.getElementById('quizScreen');
const resultsScreen = document.getElementById('resultsScreen');
const categoryGrid  = document.getElementById('categoryGrid');
const difficultyRow = document.getElementById('difficultyRow');
const startBtn      = document.getElementById('startBtn');
const quizMeta      = document.getElementById('quizMeta');
const timerBar      = document.getElementById('timerBar');
const timerText     = document.getElementById('timerText');
const progressFill  = document.getElementById('progressFill');
const questionNum   = document.getElementById('questionNum');
const questionText  = document.getElementById('questionText');
const optionsGrid   = document.getElementById('optionsGrid');
const explanation   = document.getElementById('explanation');
const btnNext       = document.getElementById('btnNext');
const scoreStrip    = document.getElementById('scoreStrip');
const resultsPct    = document.getElementById('resultsPct');
const resultsTitle  = document.getElementById('resultsTitle');
const resultsSub    = document.getElementById('resultsSub');
const statCorrect   = document.getElementById('statCorrect');
const statWrong     = document.getElementById('statWrong');
const statTime      = document.getElementById('statTime');
const playAgainBtn  = document.getElementById('playAgainBtn');
const reviewBtn     = document.getElementById('reviewBtn');
const reviewList    = document.getElementById('reviewList');

// ─── BUILD HOME ──────────────────────────────────────────────────
CATEGORIES.forEach(cat => {
  const card = document.createElement('div');
  card.className = 'category-card';
  card.style.setProperty('--cat-color', cat.color);
  card.innerHTML = `<span class="cat-icon">${cat.icon}</span><div class="cat-name">${cat.name}</div><div class="cat-count">15 Questions</div>`;
  card.addEventListener('click', () => {
    document.querySelectorAll('.category-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
    selectedCategory = cat;
    startBtn.disabled = false;
  });
  categoryGrid.appendChild(card);
});

difficultyRow.querySelectorAll('.diff-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    difficultyRow.querySelectorAll('.diff-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    selectedDifficulty = btn.dataset.diff;
  });
});

startBtn.addEventListener('click', startQuiz);

// ─── QUIZ LOGIC ──────────────────────────────────────────────────
function shuffle(arr) { return [...arr].sort(() => Math.random() - 0.5); }

function startQuiz() {
  questions = shuffle(selectedCategory.questions[selectedDifficulty]);
  currentQ = 0; score = 0; correct = 0; wrong = 0;
  userAnswers = []; timePerQ = [];
  showScreen(quizScreen);
  renderQuestion();
}

function renderQuestion() {
  if (currentQ >= questions.length) { endQuiz(); return; }

  const q = questions[currentQ];
  answered = false;
  explanation.classList.remove('show');
  btnNext.classList.remove('show');
  scoreStrip.innerHTML = '';

  const pct = (currentQ / questions.length) * 100;
  progressFill.style.width = pct + '%';
  questionNum.textContent = `Question ${currentQ + 1} of ${questions.length}`;
  questionText.textContent = q.q;
  quizMeta.innerHTML = `<span>${selectedCategory.name}</span> · ${selectedDifficulty.toUpperCase()}`;

  const letters = ['A','B','C','D'];
  optionsGrid.innerHTML = '';
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'option-btn';
    btn.innerHTML = `<span class="option-letter">${letters[i]}</span>${opt}`;
    btn.addEventListener('click', () => handleAnswer(i, btn, q));
    optionsGrid.appendChild(btn);
  });

  startTimer(30);
}

function handleAnswer(chosen, clickedBtn, q) {
  if (answered) return;
  answered = true;
  clearInterval(timerInterval);

  const elapsed = 30 - timeLeft;
  timePerQ.push(elapsed);
  userAnswers.push({ q: q.q, chosen, correct: q.ans, opts: q.opts });

  const allBtns = optionsGrid.querySelectorAll('.option-btn');
  allBtns.forEach((btn, i) => {
    btn.disabled = true;
    if (i === q.ans) btn.classList.add('correct');
    else if (i === chosen && chosen !== q.ans) btn.classList.add('wrong');
  });

  if (chosen === q.ans) {
    correct++;
    score += selectedDifficulty === 'easy' ? 10 : selectedDifficulty === 'medium' ? 15 : 20;
  } else {
    wrong++;
  }

  explanation.innerHTML = `<strong>💡 Explanation:</strong> ${q.exp}`;
  explanation.classList.add('show');
  btnNext.classList.add('show');
  btnNext.textContent = currentQ < questions.length - 1 ? 'Next Question →' : 'See Results →';

  updateScoreStrip();
}

function updateScoreStrip() {
  const pills = userAnswers.map((a, i) => {
    const cls = a.chosen === a.correct ? 'good' : 'bad';
    return `<span class="score-pill ${cls}">Q${i+1}</span>`;
  }).join('');
  scoreStrip.innerHTML = pills;
}

btnNext.addEventListener('click', () => { currentQ++; renderQuestion(); });

function startTimer(secs) {
  timeLeft = secs; totalTime = secs;
  timerBar.style.strokeDasharray = TIMER_CIRCUMFERENCE;
  updateTimerUI();

  clearInterval(timerInterval);
  timerInterval = setInterval(() => {
    timeLeft--;
    updateTimerUI();
    if (timeLeft <= 0) {
      clearInterval(timerInterval);
      if (!answered) {
        // Auto-skip
        answered = true;
        timePerQ.push(totalTime);
        userAnswers.push({ q: questions[currentQ].q, chosen: -1, correct: questions[currentQ].ans, opts: questions[currentQ].opts });
        wrong++;
        const allBtns = optionsGrid.querySelectorAll('.option-btn');
        allBtns.forEach((btn, i) => { btn.disabled = true; if (i === questions[currentQ].ans) btn.classList.add('correct'); });
        explanation.innerHTML = `<strong>⏰ Time's up!</strong> ${questions[currentQ].exp}`;
        explanation.classList.add('show');
        btnNext.classList.add('show');
        btnNext.textContent = currentQ < questions.length - 1 ? 'Next Question →' : 'See Results →';
        updateScoreStrip();
      }
    }
  }, 1000);
}

function updateTimerUI() {
  const ratio = timeLeft / totalTime;
  const offset = TIMER_CIRCUMFERENCE * (1 - ratio);
  timerBar.style.strokeDashoffset = offset;
  timerText.textContent = timeLeft;

  const color = timeLeft > 10 ? 'var(--accent)' : timeLeft > 5 ? 'var(--accent3)' : 'var(--wrong)';
  timerBar.style.stroke = color;
  timerText.style.color = color;
}

// ─── RESULTS ─────────────────────────────────────────────────────
function endQuiz() {
  clearInterval(timerInterval);
  const pct = Math.round((correct / questions.length) * 100);
  const avgTime = Math.round(timePerQ.reduce((a,b)=>a+b,0) / timePerQ.length);

  resultsPct.textContent = pct + '%';
  statCorrect.textContent = correct;
  statWrong.textContent = wrong;
  statTime.textContent = avgTime + 's';

  let title, sub;
  if (pct >= 90) { title = 'LEGENDARY!'; sub = "You absolutely crushed it. Top of the class! 🏆"; confetti(); }
  else if (pct >= 70) { title = 'WELL DONE!'; sub = "Solid performance. You clearly know your stuff! ⚡"; }
  else if (pct >= 50) { title = 'NOT BAD!'; sub = "Halfway there. Keep practising and you'll ace it! 💪"; }
  else { title = 'KEEP GOING!'; sub = "Every expert was once a beginner. Try again! 🔄"; }

  resultsTitle.textContent = title;
  resultsSub.textContent = sub;
  reviewList.innerHTML = '';
  reviewList.style.display = 'none';

  showScreen(resultsScreen);
}

playAgainBtn.addEventListener('click', () => { showScreen(homeScreen); });

let reviewOpen = false;
reviewBtn.addEventListener('click', () => {
  reviewOpen = !reviewOpen;
  if (reviewOpen) {
    reviewList.style.display = 'block';
    reviewList.innerHTML = userAnswers.map((a, i) => {
      const wasRight = a.chosen === a.correct;
      return `<div class="review-item ${wasRight ? 'r-correct' : 'r-wrong'}">
        <div class="review-q"><strong>Q${i+1}:</strong> ${a.q}</div>
        <div class="review-answers">
          <span class="review-your ${wasRight ? 'was-right' : ''}">Your answer: ${a.chosen === -1 ? 'Timed out' : a.opts[a.chosen]}</span>
          ${!wasRight ? `<span class="review-correct-ans">✓ Correct: ${a.opts[a.correct]}</span>` : ''}
        </div>
      </div>`;
    }).join('');
    reviewBtn.textContent = 'Hide Answers';
  } else {
    reviewList.style.display = 'none';
    reviewBtn.textContent = 'Review Answers';
  }
});

// ─── SCREENS ─────────────────────────────────────────────────────
function showScreen(el) {
  [homeScreen, quizScreen, resultsScreen].forEach(s => s.classList.remove('active'));
  el.classList.add('active');
}

// ─── CONFETTI ────────────────────────────────────────────────────
function confetti() {
  const wrap = document.getElementById('confettiWrap');
  wrap.innerHTML = '';
  const colors = ['#00e5ff','#ff3cac','#ffd60a','#00ff88','#a855f7'];
  for (let i = 0; i < 80; i++) {
    const bit = document.createElement('div');
    bit.className = 'confetti-bit';
    bit.style.cssText = `
      left: ${Math.random()*100}%;
      top: -10px;
      background: ${colors[Math.floor(Math.random()*colors.length)]};
      animation-duration: ${1.5 + Math.random()*2}s;
      animation-delay: ${Math.random()*0.8}s;
      width: ${6 + Math.random()*8}px;
      height: ${6 + Math.random()*8}px;
      border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
    `;
    wrap.appendChild(bit);
  }
  setTimeout(() => wrap.innerHTML = '', 4000);
}
</script>
