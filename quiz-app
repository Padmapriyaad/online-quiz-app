<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QUIZMASTER — Test Your Mind</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0d71;
    --surface: #0f0f9f;
    --card: #16161f;
    --border: #2a2a3a;
    --accent: #00e5ff;
    --accent2: #ff3cac;
    --accent3: #ffd60a;
    --text: #e8e8f0;
    --muted: #6b6b88;
    --correct: #00ff88;
    --wrong: #ff4466;
    --glow: 0 0 20px rgba(0,229,255,0.3);
    --glow2: 0 0 20px rgba(255,60,172,0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Animated grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(0,229,255,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .app {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  /* ── SCREENS ── */
  .screen { display: none; width: 100%; max-width: 720px; animation: fadeUp 0.4s ease; }
  .screen.active { display: block; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── HEADER ── */
  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 10vw, 88px);
    letter-spacing: 4px;
    line-height: 1;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-align: center;
    filter: drop-shadow(0 0 30px rgba(0,229,255,0.4));
  }

  .logo-sub {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    letter-spacing: 6px;
    color: var(--muted);
    text-align: center;
    margin-top: 6px;
    text-transform: uppercase;
  }

  /* ── CATEGORIES ── */
  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-top: 40px;
  }

  .category-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 24px;
    cursor: pointer;
    transition: all 0.25s ease;
    position: relative;
    overflow: hidden;
  }

  .category-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--cat-color, var(--accent)), transparent 60%);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .category-card:hover { 
    border-color: var(--cat-color, var(--accent)); 
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
  }
  .category-card:hover::before { opacity: 0.08; }

  .category-card.selected {
    border-color: var(--cat-color, var(--accent));
    box-shadow: 0 0 0 1px var(--cat-color, var(--accent)), 0 8px 32px rgba(0,0,0,0.3);
  }
  .category-card.selected::before { opacity: 0.12; }

  .cat-icon { font-size: 36px; margin-bottom: 14px; display: block; }
  .cat-name {
    font-family: 'Space Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.5px;
  }
  .cat-count {
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
  }

  /* ── DIFFICULTY ── */
  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--muted);
    text-transform: uppercase;
    margin: 36px 0 16px;
  }

  .difficulty-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .diff-btn {
    flex: 1;
    min-width: 90px;
    padding: 14px 20px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--muted);
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.2s ease;
    text-transform: uppercase;
  }

  .diff-btn:hover { border-color: var(--accent); color: var(--accent); }
  .diff-btn.active { 
    border-color: var(--accent);
    background: rgba(0,229,255,0.08);
    color: var(--accent);
    box-shadow: var(--glow);
  }

  /* ── START BUTTON ── */
  .btn-primary {
    width: 100%;
    padding: 18px;
    margin-top: 32px;
    border-radius: 12px;
    border: none;
    background: linear-gradient(135deg, var(--accent), #0099bb);
    color: #000;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 3px;
    cursor: pointer;
    transition: all 0.25s ease;
    box-shadow: 0 4px 20px rgba(0,229,255,0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0,229,255,0.5);
  }

  .btn-primary:active { transform: translateY(0); }
  .btn-primary:disabled { opacity: 0.35; cursor: not-allowed; transform: none; }

  /* ── QUIZ SCREEN ── */
  .quiz-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
    gap: 16px;
  }

  .quiz-meta {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 1px;
  }

  .quiz-meta span { color: var(--accent); }

  /* Timer */
  .timer-ring {
    position: relative;
    width: 58px;
    height: 58px;
    flex-shrink: 0;
  }

  .timer-ring svg {
    transform: rotate(-90deg);
    width: 58px;
    height: 58px;
  }

  .timer-track { fill: none; stroke: var(--border); stroke-width: 3; }
  .timer-bar {
    fill: none;
    stroke: var(--accent);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 138;
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 1s linear, stroke 0.3s ease;
  }

  .timer-text {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 15px;
    font-weight: 700;
    color: var(--accent);
    transition: color 0.3s ease;
  }

  /* Progress bar */
  .progress-bar {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    margin-bottom: 28px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  /* Question card */
  .question-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 36px;
  }

  .question-num {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .question-text {
    font-size: clamp(18px, 3vw, 22px);
    font-weight: 500;
    line-height: 1.5;
    color: var(--text);
    margin-bottom: 32px;
  }

  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  @media (max-width: 480px) { .options-grid { grid-template-columns: 1fr; } }

  .option-btn {
    position: relative;
    padding: 16px 20px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .option-letter {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .option-btn:hover:not(:disabled) {
    border-color: var(--accent);
    background: rgba(0,229,255,0.05);
  }

  .option-btn:hover:not(:disabled) .option-letter {
    background: var(--accent);
    color: #000;
  }

  .option-btn.correct {
    border-color: var(--correct);
    background: rgba(0,255,136,0.08);
    color: var(--correct);
    animation: pulse-correct 0.4s ease;
  }

  .option-btn.correct .option-letter {
    background: var(--correct);
    color: #000;
  }

  .option-btn.wrong {
    border-color: var(--wrong);
    background: rgba(255,68,102,0.08);
    color: var(--wrong);
    animation: shake 0.4s ease;
  }

  .option-btn.wrong .option-letter {
    background: var(--wrong);
    color: #fff;
  }

  .option-btn:disabled { cursor: not-allowed; }

  @keyframes pulse-correct {
    0% { transform: scale(1); }
    40% { transform: scale(1.03); }
    100% { transform: scale(1); }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-5px); }
    60% { transform: translateX(5px); }
  }

  /* Explanation */
  .explanation {
    margin-top: 20px;
    padding: 16px 20px;
    border-radius: 10px;
    background: rgba(0,229,255,0.05);
    border-left: 3px solid var(--accent);
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    display: none;
  }

  .explanation.show { display: block; animation: fadeUp 0.3s ease; }
  .explanation strong { color: var(--accent); }

  /* Next button */
  .btn-next {
    width: 100%;
    padding: 16px;
    margin-top: 20px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    display: none;
  }

  .btn-next.show { display: block; animation: fadeUp 0.3s ease; }
  .btn-next:hover { border-color: var(--accent); color: var(--accent); }

  /* Score strip */
  .score-strip {
    display: flex;
    gap: 12px;
    margin-top: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .score-pill {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    padding: 8px 16px;
    border-radius: 100px;
    background: var(--card);
    border: 1px solid var(--border);
  }

  .score-pill.good { border-color: var(--correct); color: var(--correct); }
  .score-pill.bad { border-color: var(--wrong); color: var(--wrong); }

  /* ── RESULTS ── */
  .results-center { text-align: center; }

  .results-badge {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 3px solid var(--accent);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0 auto 32px;
    box-shadow: var(--glow), inset 0 0 40px rgba(0,229,255,0.05);
    animation: badge-in 0.6s cubic-bezier(0.34,1.56,0.64,1);
  }

  @keyframes badge-in {
    from { transform: scale(0.5); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  .results-score {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 52px;
    color: var(--accent);
    line-height: 1;
  }

  .results-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
  }

  .results-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 42px;
    letter-spacing: 2px;
    margin-bottom: 8px;
  }

  .results-sub {
    color: var(--muted);
    font-size: 15px;
    margin-bottom: 36px;
    line-height: 1.5;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 32px;
  }

  .stat-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px 12px;
    text-align: center;
  }

  .stat-val {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: var(--text);
    line-height: 1;
  }

  .stat-val.green { color: var(--correct); }
  .stat-val.red { color: var(--wrong); }

  .stat-lbl {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--muted);
    margin-top: 6px;
    text-transform: uppercase;
  }

  /* Review */
  .review-list { margin-top: 32px; text-align: left; }
  .review-item {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    margin-bottom: 12px;
    border-left: 3px solid var(--border);
    transition: border-color 0.2s;
  }
  .review-item.r-correct { border-left-color: var(--correct); }
  .review-item.r-wrong { border-left-color: var(--wrong); }

  .review-q {
    font-size: 14px;
    color: var(--text);
    margin-bottom: 10px;
    line-height: 1.4;
  }

  .review-answers {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    font-family: 'Space Mono', monospace;
    font-size: 11px;
  }

  .review-your { color: var(--wrong); }
  .review-your.was-right { color: var(--correct); }
  .review-correct-ans { color: var(--correct); }

  .btn-ghost {
    width: 100%;
    padding: 16px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 12px;
  }
  .btn-ghost:hover { border-color: var(--accent2); color: var(--accent2); }

  /* Confetti bits */
  .confetti-wrap {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    overflow: hidden;
  }

  .confetti-bit {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    animation: fall linear forwards;
  }

  @keyframes fall {
    0% { transform: translateY(-20px) rotate(0deg); opacity: 1; }
    100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
  }
</style>
</head>
<body>
<div class="confetti-wrap" id="confettiWrap"></div>
<div class="app">

  <!-- HOME SCREEN -->
  <div class="screen active" id="homeScreen">
    <div class="logo">QUIZMASTER</div>
    <div class="logo-sub">Test Your Mind · Challenge Your Limits</div>

    <div class="section-label" style="margin-top:44px;">Choose Category</div>
    <div class="category-grid" id="categoryGrid"></div>

    <div class="section-label">Difficulty</div>
    <div class="difficulty-row" id="difficultyRow">
      <button class="diff-btn active" data-diff="easy">Easy</button>
      <button class="diff-btn" data-diff="medium">Medium</button>
      <button class="diff-btn" data-diff="hard">Hard</button>
    </div>

    <button class="btn-primary" id="startBtn" disabled>Start Quiz</button>
  </div>

  <!-- QUIZ SCREEN -->
  <div class="screen" id="quizScreen">
    <div class="quiz-header">
      <div class="quiz-meta" id="quizMeta"></div>
      <div class="timer-ring">
        <svg viewBox="0 0 46 46">
          <circle class="timer-track" cx="23" cy="23" r="22"/>
          <circle class="timer-bar" id="timerBar" cx="23" cy="23" r="22"/>
        </svg>
        <div class="timer-text" id="timerText">30</div>
      </div>
    </div>
    <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
    <div class="question-card">
      <div class="question-num" id="questionNum"></div>
      <div class="question-text" id="questionText"></div>
      <div class="options-grid" id="optionsGrid"></div>
      <div class="explanation" id="explanation"></div>
      <button class="btn-next" id="btnNext">Next Question →</button>
    </div>
    <div class="score-strip" id="scoreStrip"></div>
  </div>

  <!-- RESULTS SCREEN -->
  <div class="screen" id="resultsScreen">
    <div class="results-center">
      <div class="results-badge">
        <div class="results-score" id="resultsPct">0%</div>
        <div class="results-label">Score</div>
      </div>
      <div class="results-title" id="resultsTitle">Great Job!</div>
      <div class="results-sub" id="resultsSub"></div>
      <div class="stats-grid">
        <div class="stat-box">
          <div class="stat-val green" id="statCorrect">0</div>
          <div class="stat-lbl">Correct</div>
        </div>
        <div class="stat-box">
          <div class="stat-val red" id="statWrong">0</div>
          <div class="stat-lbl">Wrong</div>
        </div>
        <div class="stat-box">
          <div class="stat-val" id="statTime">0s</div>
          <div class="stat-lbl">Avg Time</div>
        </div>
      </div>
      <button class="btn-primary" id="playAgainBtn">Play Again</button>
      <button class="btn-ghost" id="reviewBtn">Review Answers</button>
    </div>
    <div class="review-list" id="reviewList" style="display:none;"></div>
  </div>

</div>

<script>
// ─── DATA ───────────────────────────────────────────────────────
const CATEGORIES = [
  {
    id: 'science', name: 'Science', icon: '⚗️', color: '#00e5ff',
    questions: {
      easy: [
        { q: 'What planet is known as the Red Planet?', opts: ['Mars','Venus','Jupiter','Saturn'], ans: 0, exp: 'Mars has iron oxide on its surface giving it a reddish appearance.' },
        { q: 'What gas do plants absorb from the atmosphere?', opts: ['Oxygen','Nitrogen','Carbon Dioxide','Hydrogen'], ans: 2, exp: 'Plants absorb CO₂ during photosynthesis and release oxygen.' },
        { q: 'How many bones are in the adult human body?', opts: ['186','206','226','246'], ans: 1, exp: 'An adult human has 206 bones. Babies are born with around 270.' },
        { q: 'What is the chemical symbol for gold?', opts: ['Go','Gd','Au','Ag'], ans: 2, exp: 'Au comes from the Latin word "aurum" meaning gold.' },
        { q: 'What force keeps us on the ground?', opts: ['Magnetism','Gravity','Friction','Tension'], ans: 1, exp: 'Gravity is the attractive force between objects with mass.' },
      ],
      medium: [
        { q: 'What is the speed of light in a vacuum (approx)?', opts: ['150,000 km/s','300,000 km/s','450,000 km/s','600,000 km/s'], ans: 1, exp: 'The speed of light is approximately 299,792 km/s.' },
        { q: 'Which organ produces insulin?', opts: ['Liver','Kidney','Pancreas','Heart'], ans: 2, exp: 'The pancreas produces insulin to regulate blood glucose levels.' },
        { q: 'What is the most abundant element in the universe?', opts: ['Helium','Oxygen','Carbon','Hydrogen'], ans: 3, exp: 'Hydrogen makes up about 75% of all baryonic matter in the universe.' },
        { q: 'DNA stands for?', opts: ['Deoxyribonucleic Acid','Deoxyribose Nucleic Acid','Dinitrogen Acid','Double Nucleic Array'], ans: 0, exp: 'DNA = Deoxyribonucleic Acid, the molecule carrying genetic instructions.' },
        { q: 'What is the hardest natural substance on Earth?', opts: ['Quartz','Iron','Diamond','Titanium'], ans: 2, exp: 'Diamond scores 10 on the Mohs hardness scale, the maximum.' },
      ],
      hard: [
        { q: 'What is the half-life of Carbon-14?', opts: ['1,730 years','5,730 years','11,460 years','57,300 years'], ans: 1, exp: 'C-14 has a half-life of ~5,730 years, used in radiocarbon dating.' },
        { q: 'Which particle has no charge and nearly zero mass?', opts: ['Electron','Proton','Neutron','Neutrino'], ans: 3, exp: 'Neutrinos are electrically neutral with tiny mass, rarely interacting with matter.' },
        { q: 'The Krebs cycle takes place in which part of the cell?', opts: ['Nucleus','Ribosome','Mitochondrial matrix','Golgi apparatus'], ans: 2, exp: 'The Krebs (citric acid) cycle occurs in the mitochondrial matrix.' },
        { q: "Heisenberg's uncertainty principle relates which two quantities?", opts: ['Mass and velocity','Position and momentum','Energy and time','Charge and spin'], ans: 1, exp: 'You cannot simultaneously know both position and momentum with arbitrary precision.' },
        { q: 'What is the atomic number of Carbon?', opts: ['4','6','8','12'], ans: 1, exp: 'Carbon has 6 protons, giving it atomic number 6.' },
      ]
    }
  },
  {
    id: 'history', name: 'History', icon: '🏛️', color: '#ff3cac',
    questions: {
      easy: [
        { q: 'Who was the first President of the United States?', opts: ['Abraham Lincoln','Thomas Jefferson','George Washington','John Adams'], ans: 2, exp: 'George Washington served as the first US President from 1789 to 1797.' },
